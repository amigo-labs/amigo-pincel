{
  "name": "pincel-ui",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "lint": "eslint .",
    "format": "prettier --write .",
    "wasm:build": "wasm-pack build ../crates/pincel-wasm --target web --dev --out-dir pkg",
    "wasm:build:release": "wasm-pack build ../crates/pincel-wasm --target web --release --out-dir pkg"
  },
  "dependencies": {
    "pincel-wasm": "link:../crates/pincel-wasm/pkg"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.10.0",
    "eslint": "^9.20.0",
    "eslint-plugin-svelte": "^3.0.0",
    "globals": "^15.14.0",
    "prettier": "^3.4.0",
    "prettier-plugin-svelte": "^3.3.3",
    "svelte": "^5.20.0",
    "svelte-check": "^4.1.4",
    "svelte-eslint-parser": "^1.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.24.0",
    "vite": "^6.1.0"
  }
}
