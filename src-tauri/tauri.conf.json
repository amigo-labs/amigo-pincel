{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Pincel",
  "version": "0.1.0",
  "identifier": "app.pincel.desktop",
  "build": {
    "beforeDevCommand": "pnpm --dir ../ui dev",
    "beforeBuildCommand": "pnpm --dir ../ui build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../ui/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Pincel",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "category": "GraphicsAndDesign",
    "shortDescription": "Pixel-art editor for game asset creation.",
    "longDescription": "Pincel is a pixel-art editor at the feature level of Aseprite, focused on game asset creation. The native desktop build shares one Svelte UI and one Rust core with the PWA."
  }
}
